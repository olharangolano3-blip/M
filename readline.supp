{
    readline_leaks
    Memcheck:Leak
    match-leak-kinds: reachable
    ...
    fun:readline
    ...
}
{
    add_history_leaks
    Memcheck:Leak
    match-leak-kinds: reachable
    ...
    fun:add_history
    ...
}
{
    readline_internal_leaks
    Memcheck:Leak
    match-leak-kinds: reachable
    ...
    obj:*/libreadline.so.*
    ...
}
